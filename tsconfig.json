{
  "include": ["src", "types", "test"],
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "esnext"],
    "importHelpers": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": ".",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "strictNullChecks": true,
    "types": ["node", "jest"],
    "esModuleInterop": true
  }
}
